{
  "name": "anvil-plan-spec",
  "version": "0.7.0",
  "private": true,
  "description": "A lightweight specification format for planning and work item authorisation in AI-assisted development.",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "markdownlint \"**/*.md\"",
    "lint:fix": "markdownlint --fix \"**/*.md\"",
    "validate": "./bin/aps lint",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.49.0"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint"
    ],
    "*.sh": [
      "bash -n"
    ]
  },
  "packageManager": "pnpm@11.6.0+sha256.a0162949d1ab19e12e8b3cd9f0f59ef02d7be74a28b806cf7f49fb7f4c07e5ce"
